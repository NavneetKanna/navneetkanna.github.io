---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout>

        <!-- HERO -->
        <section id="hero">
            <div class="hero-inner">
                <div class="reveal-stagger">
                    <h1 class="hero-name">VS Navneet Kanna</h1>
                    <p class="hero-pre">Machine Learning Engineer</p>

                    <p class="hero-tagline">
                        I build ML systems end-to-end, from model design down to the GPU kernels they run on.
                    </p>

                    <div style="display: flex; gap: 0.75rem; margin-top: 1rem;">
                        <a href="/blog" class="btn btn-accent">Read the Blog &rarr;</a>
                    </div>

                </div>
            </div>
        </section>

        <!-- ABOUT -->
        <section id="about">
            <div class="container">
                <div class="section-label">About</div>
                <div class="about-bio reveal">
                    <p style="font-size: 1.15rem; color: var(--text-strong); margin-bottom: 2rem; line-height: 1.8;">
                        I got into ML because I wanted to solve hard problems with AI. Once I started learning, I got pulled into how it all actually works under the hood &mdash; that&rsquo;s how dlgrad came about. That&rsquo;s mostly how I work now: read the papers, build it from scratch, understand what&rsquo;s really going on.
                    </p>

                    <ul class="about-list reveal-stagger">
                        <li>
                            <strong>Education</strong> &mdash; MSc in Robotics &amp; AI from the University of Glasgow (2023).
                        </li>
                        <li>
                            <strong>Industry Experience</strong> &mdash; Architected and deployed production-scale Computer Vision systems, building the GPU inference infrastructure that secured a seven-figure (INR) commercial contract.
                        </li>
                        <li>
                            <strong>Projects</strong> &mdash; Built <a href="https://github.com/navneetkanna/dlgrad" target="_blank" rel="noopener">dlgrad</a> (a from-scratch autograd engine with a C/Metal backend), <strong>gradtop</strong> (a Rust-based neural network TUI), and several others &mdash; see below.
                        </li>
                        <li>
                            <strong>Academic Research</strong> &mdash; First-author publication, <em>Finding Exoplanets Using Object Detection</em> (Astrophysics &amp; Space Science, Springer 2023).
                        </li>
                        <li>
                            <strong>Technical Writing</strong> &mdash; Authored a blog series breaking down deep learning concepts, bridging the gap between mathematical theory and hardware execution.
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- PROJECTS -->
        <section id="projects">
            <div class="container">
                <div class="section-label">Projects</div>
                <div class="projects-list reveal">

                    <!-- dlgrad -->
                    <div class="project-card featured">
                        <div class="project-top">
                            <span class="project-name">dlgrad</span>
                        </div>
                        <p class="project-meta">Deep Learning Autograd Engine</p>
                        <ul class="project-bullets">
                            <li>Built a reverse-mode automatic differentiation engine with a PyTorch-like API, developed entirely from scratch to understand deep learning and backpropagation from first principles.</li>
                            <li>Written in Python with a custom C backend, with no dependencies except CFFI for Python&ndash;C communication.</li>
                            <li>Supports both CPU and Apple Metal GPU acceleration, with autogenerated handwritten kernels optimised for input shapes and operations.</li>
                            <li>Implemented the full tensor stack: broadcasting, core arithmetic ops (add, sub, mul, div), activations (ReLU), and loss functions (log-softmax, cross-entropy).</li>
                            <li>Trains networks end-to-end &mdash; including MNIST MLP and GAN implementations.</li>
                            <li>Implemented a full GPT model in dlgrad and successfully trained it on the TinyStories dataset to generate text.</li>
                            <li>Supports saving and loading models in safetensors format. Pip-installable.</li>
                        </ul>
                        <div class="project-bottom">
                            <a href="https://github.com/navneetkanna/dlgrad" target="_blank" rel="noopener" class="btn btn-accent">GitHub &rarr;</a>
                        </div>
                    </div>

                    <!-- gradtop -->
                    <div class="project-card">
                        <div class="project-top">
                            <span class="project-name">gradtop</span>
                        </div>
                        <p class="project-meta">Real-time Neural Network TUI</p>
                        <ul class="project-bullets">
                            <li>Built a terminal UI in Rust to visualise neural network training metrics in real time.</li>
                            <li>Wrote Python bindings to hook directly into deep learning training loops and stream live data.</li>
                            <li>Renders high-frequency updates &mdash; loss curves, gradients &mdash; directly in the terminal with minimal overhead.</li>
                        </ul>
                        <!-- TODO: add GitHub link if the repo is public -->
                    </div>

                    <!-- fcount -->
                    <div class="project-card">
                        <div class="project-top">
                            <span class="project-name">fcount</span>
                        </div>
                        <p class="project-meta">High-Performance File System Counter</p>
                        <ul class="project-bullets">
                            <li>A high-performance command-line tool in Rust designed to outperform standard Linux utilities (<code>ls</code>, <code>wc</code>) for file system statistics.</li>
                            <li>Achieved a 3.4&times; speedup over GNU coreutils (<code>ls</code>) and a 1.7&times; speedup over Go-based alternatives (<code>gdu</code>).</li>
                            <li>Main optimisation: bypass redundant <code>stat()</code> syscalls by leveraging Linux <code>d_type</code> directly from the kernel buffer, reducing system/kernel CPU time by 50%.</li>
                            <li>CI/CD pipeline via GitHub Actions builds, tests, and releases cross-platform binaries for Linux (x86_64) and macOS (Apple Silicon).</li>
                        </ul>
                        <!-- TODO: add GitHub link if the repo is public -->
                    </div>

                    <!-- Exoplanet detection -->
                    <div class="project-card">
                        <div class="project-top">
                            <span class="project-name">Finding Exoplanets using Object Detection</span>
                        </div>
                        <p class="project-meta">Bachelor&rsquo;s Final-Semester Group Project</p>
                        <ul class="project-bullets">
                            <li>Helped astronomers analyse large volumes of light curve data from the TESS satellite.</li>
                            <li>Used the YOLOv5 algorithm to detect dips in light curve images.</li>
                            <li>Final model achieved 82% mAP and accurately detected dips on the test set.</li>
                            <li>Published as first author in <em>Astrophysics &amp; Space Science</em>, Springer 2023 &mdash; see Research below.</li>
                        </ul>
                    </div>

                    <!-- MSc Dissertation -->
                    <div class="project-card">
                        <div class="project-top">
                            <span class="project-name">Modelling Superconducting Flux Pumps for Fusion</span>
                        </div>
                        <p class="project-meta">MSc Dissertation &mdash; University of Glasgow</p>
                        <ul class="project-bullets">
                            <li>Investigated whether machine learning models can replace numerical models for simulating flux pumps in fusion applications.</li>
                            <li>Numerical models are computationally expensive, making them impractical for heavy fusion simulation workloads.</li>
                            <li>Trained 5 ML models on a dataset generated from numerical simulations.</li>
                            <li>Concluded with strong evidence that ML models are a viable alternative to traditional numerical methods for this domain.</li>
                        </ul>
                    </div>

                </div>
            </div>
        </section>

        <!-- PUBLICATION -->
        <section id="publication">
            <div class="container">
                <div class="section-label">Research</div>
                <div class="pub-card reveal">
                    <div class="pub-top">
                        <div>
                            <div class="pub-venue">Astrophysics &amp; Space Science &nbsp;&middot;&nbsp; Springer Nature &nbsp;&middot;&nbsp; Vol. 368 &nbsp;&middot;&nbsp; 2023</div>
                            <div class="pub-title">Finding Exoplanets Using Object Detection</div>
                            <div class="pub-authors">
                                S. R. Mani Sekhar, C. Tejas,
                                <strong>V. S. Navneet Kanna</strong>,
                                Aasees Kaur
                            </div>
                        </div>
                        <div class="pub-link-group">
                            <a href="https://link.springer.com/article/10.1007/s10509-023-04232-z"
                               target="_blank" rel="noopener" class="btn btn-accent">Springer &rarr;</a>
                            <a href="https://ui.adsabs.harvard.edu/abs/2023Ap%26SS.368...75S/abstract"
                               target="_blank" rel="noopener" class="btn">NASA ADS &rarr;</a>
                        </div>
                    </div>
                    <div class="pub-meta-row">
                        <span class="pub-meta-item">Article 75</span>
                        <span class="pub-meta-item">DOI: 10.1007/s10509-023-04232-z</span>
                        <span class="pub-meta-item">450+ Accesses &middot; 2 Citations</span>
                        <span class="pub-meta-item">Indexed: Harvard ADS</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- CONTACT -->
        <section id="contact">
            <div class="container">
                <div class="section-label">Contact</div>
                <div class="contact-grid reveal">
                    <div>
                        <h2 class="contact-heading">Let&rsquo;s talk.</h2>
                        <p class="contact-body">
                            Open to research collaborations, ML roles, and conversations.
                        </p>
                        <!-- TODO: replace with your actual email -->
                        <a href="mailto:you@navneetkanna.com" class="contact-email">
                            navneetkanna04@gmail.com
                        </a>
                    </div>

