---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;

// Format the date for the post page
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC'
});
---

<BaseLayout>
    <main class="container" style="padding-top: 8rem; padding-bottom: 6rem; max-width: 760px;">
        <a href="/blog" style="font-family: var(--font-mono); font-size: 0.8rem; margin-bottom: 2rem; display: inline-block;">&larr; Back to Blog</a>
        
        <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; color: var(--text-strong); margin-bottom: 0.5rem; line-height: 1.2;">
            {frontmatter.title}
        </h1>
        <p style="font-family: var(--font-mono); color: var(--accent); font-size: 0.85rem; margin-bottom: 3rem;">
            {formattedDate}
        </p>

        <article class="blog-content">
            <slot />
        </article>
    </main>
</BaseLayout>
